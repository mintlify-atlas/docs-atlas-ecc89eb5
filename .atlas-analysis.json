  "keyFeatures": [
    "SQL-like query language: FROM, WHERE, GROUP BY, SHOW",
    "Temporal correlation: WITHIN 5s OF finds events near other events",
    "Auto-detects JSON, logfmt, and plain text log formats",
    "Single static binary, zero dependencies, built in Zig",
    "Follow mode: real-time tail with live filtering",
    "Explain mode: shows query execution plan",
    "Multiple output formats: text, NDJSON, raw",
    "2–6x faster than jq for structured log queries",
    "Nested field access with dot notation",
    "Shell completions for bash, zsh, and fish"
  ],
  "publicApiSurface": [
    "zeal '<query>'",
    "FROM <source>[, <source>]",
    "WHERE <expression>",
    "GROUP BY <field>[, <field>]",
    "SHOW FIRST|LAST <n> | SHOW COUNT",
    "WITHIN <duration> OF <expression>",
    "CONTAINS operator",
    "MATCHES operator",
    "AND / OR / NOT boolean logic",
    "--format text|json|raw",
    "--follow / -F",
    "--explain",
    "--color auto|always|never",
    "--no-color",
    "-f / --file <path>"
  ]
