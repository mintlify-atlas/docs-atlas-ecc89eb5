  "colors": {
    "primary": "#94cb04",
    "light": "#545454"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "https://media.brand.dev/288cc7c4-5cef-4376-950b-bdf0083eedae.png",
